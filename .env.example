# Supabase — required for the shared database, admin auth, and image uploads.
# Without these the app silently falls back to per-browser localStorage
# (data/images live only in your own browser and are NOT visible to visitors).
#
# Get these from your Supabase project: Settings -> API.
# The anon (publishable) key is safe to expose in a static build; Row-Level
# Security protects the data. Copy this file to .env for local dev, and add
# the same two values as GitHub Actions repository secrets for deployment.
VITE_SUPABASE_URL=https://meytyveimchuylbortwl.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_uNGeF9WH_MRlKi2Csby0Ag_luhbtRJV

# Optional — only needed for a GitHub "project page" served from a subpath,
# e.g. https://username.github.io/REPO-NAME/ -> set VITE_BASE=/REPO-NAME/
# Leave unset for a user/org page (username.github.io) or a custom domain.
# VITE_BASE=/AV0507/
